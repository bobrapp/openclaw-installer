{
  "name": "openclaw-installer",
  "version": "2.4.1",
  "description": "Guided macOS/cloud installer for OpenClaw — preflight checks, dependency validation, 1-click deploy, hardening checklist, and rollback support. 16 host targets, 87 marketplace entries, 15 languages.",
  "license": "Apache-2.0 WITH Commons-Clause",
  "type": "module",
  "bin": {
    "openclaw": "./bin/openclaw.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "scripts/",
    "public/*.html",
    "public/*.pdf",
    "package.json",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bobrapp/openclaw-installer.git"
  },
  "homepage": "https://github.com/bobrapp/openclaw-installer",
  "bugs": {
    "url": "https://github.com/bobrapp/openclaw-installer/issues"
  },
  "keywords": [
    "openclaw",
    "installer",
    "aigovops",
    "ai-governance",
    "macos",
    "cloud-deploy",
    "devops",
    "hardening",
    "security",
    "compliance"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "contributors": [
    "Ken Johnston <ken@aigovopsfoundation.org>",
    "Bob Rapp <bobrapp@hotmail.com>"
  ],
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "tsx script/build.ts",
    "start": "NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@jridgewell/trace-mapping": "^0.3.25",
    "@radix-ui/react-accordion": "^1.2.4",

    "embla-carousel-react": "^8.6.0",
    "express": "^5.0.1",
    "express-rate-limit": "^8.3.2",
    "framer-motion": "^12.38.0",
    "helmet": "^8.1.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
